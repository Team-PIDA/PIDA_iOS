import XCTest
import ComposableArchitecture
@testable import {{ name }}FeatureInterface

final class {{ name }}UnitTests: XCTestCase {
    
    func testIncrement() {
        let store = TestStore(initialState: {{ name }}Feature.State()) {
            {{ name }}Feature()
        }

        store.send(.increment) {
            $0.count = 1
        }
    }

    func testDecrement() {
        let store = TestStore(initialState: {{ name }}Feature.State()) {
            {{ name }}Feature()
        }

        store.send(.decrement) {
            $0.count = -1
        }
    }
}
