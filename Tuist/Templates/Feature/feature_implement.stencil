import {{ name }}FeatureInterface
import ComposableArchitecture

extension {{ name }}Feature {
  public init() {
    let reducer = Reduce<State, Action> { state, action in
      switch action {
      default:
        return .none
      }
    }
    self.init(reducer: reducer)
  }
}
