default_platform(:ios)

platform :ios do

  # ================================
  # Match - 인증서 동기화
  # ================================

  desc "Development 인증서 동기화 (readonly)"
  lane :sync_dev_certs do
    match(
      type: "development",
      readonly: true
    )
  end

  desc "AppStore 인증서 동기화 (readonly)"
  lane :sync_appstore_certs do
    match(
      type: "appstore",
      readonly: true
    )
  end

  desc "모든 인증서 동기화 (readonly)"
  lane :sync_all_certs do
    match(
      type: "development",
      readonly: true
    )
    match(
      type: "appstore",
      readonly: true
    )
  end

  # ================================
  # Match - 인증서 생성 (최초 1회)
  # ================================

  desc "Development 인증서 생성"
  lane :create_dev_certs do
    match(
      type: "development",
      readonly: false
    )
  end

  desc "AppStore 인증서 생성"
  lane :create_appstore_certs do
    match(
      type: "appstore",
      readonly: false
    )
  end

  desc "모든 인증서 생성"
  lane :create_all_certs do
    match(
      type: "development",
      readonly: false
    )
    match(
      type: "appstore",
      readonly: false
    )
  end

  # ================================
  # Match - 인증서 갱신 (강제)
  # ================================

  desc "Development 인증서 갱신 (기존 삭제 후 재생성)"
  lane :renew_dev_certs do
    match(
      type: "development",
      force: true
    )
  end

  desc "AppStore 인증서 갱신 (기존 삭제 후 재생성)"
  lane :renew_appstore_certs do
    match(
      type: "appstore",
      force: true
    )
  end

end
