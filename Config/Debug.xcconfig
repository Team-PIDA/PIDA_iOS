BUNDLE_ID_SUFFIX = .dev
EXCLUDE_RESOURCE = Resources/Release/**
OTHER_SWIFT_FLAGS[config=DEBUG][sdk=*] = $(inherited) -DDEBUG
SWIFT_OPTIMIZATION_LEVEL = -Onone

#include? "Debug-Secrets.xcconfig"
NM_CLIENT_ID = ${NM_CLIENT_ID}
BASE_URL = ${BASE_URL}
BASE_URL_V2 = ${BASE_URL_V2}
MIXPANEL_TOKEN = ${MIXPANEL_TOKEN}
FACEBOOK_APP_ID = ${FACEBOOK_APP_ID}
FACEBOOK_CLIENT_TOKEN = ${FACEBOOK_CLIENT_TOKEN}
